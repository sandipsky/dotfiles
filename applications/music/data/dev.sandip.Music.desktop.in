[Desktop Entry]
Name=Music
GenericName=Music Player
Comment=Play your music collection
Exec=@BINDIR@/music %U
Icon=@APP_ID@
Terminal=false
Type=Application
Categories=GTK;Audio;AudioVideo;Music;Player;
MimeType=audio/mpeg;audio/mp4;audio/x-m4a;audio/flac;audio/x-flac;audio/ogg;audio/x-vorbis+ogg;audio/x-opus+ogg;audio/opus;audio/wav;audio/x-wav;audio/aac;audio/x-aac;audio/aiff;audio/x-aiff;audio/ape;audio/x-ape;audio/wma;audio/x-ms-wma;application/ogg;application/x-ogg;
Keywords=Music;Player;Audio;Sound;
StartupNotify=true
