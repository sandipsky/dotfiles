{
    "hyprland/workspaces": {
        "on-click": "activate",
        "active-only": false,
        "all-outputs": true,
        "format": "{}",
        "format-icons": {
            "urgent": "",
            "active": "",
            "default": ""
        },
        "persistent-workspaces": {
            "*": 4
        }
    },
    "hyprland/window": {
        "format": "{class}",
        "separate-outputs": true
    },
    "custom/appmenu": {
        "format": "ΎΗΤ",
        "on-click": "rofi -disable-history -drun-match-fields name -show drun -theme-str '@import \"app.rasi\"'",
        "tooltip": false
    },
    "custom/exit": {
        "format": "ΎΑΣ",
        "on-click": "$HOME/.local/bin/powermenu",
        "tooltip": false
    },
    "tray": {
        "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        "format": "<span color=\"#6D8895\">ΎΑΩ</span>  {:%I:%M %p}",
        "tooltip-format": "<tt><big>{calendar}</big></tt>",
        "format-alt": "<span color=\"#fff\">≤░Δφ</span>  {:%Y-%m-%d, %a}"
    },
    "cpu": {
        "interval": 5,
        "format": "<span color=\"#f7768e\">ΎΜδ</span>  {}%",
        "max-length": 10
    },
    "memory": {
        "interval": 5,
        "format": "<span color=\"#FBC02D\">ΎΦ╕</span>  {used} GiB",
        "max-length": 10
    },
    "network": {
        "format": "{ifname}",
        "format-wifi": "<span color=\"#4DD0E1\">ΎΘτ</span>  {essid}",
        "format-ethernet": "ΎηΨ  {ifname}",
        "format-disconnected": "Disconnected",
        "tooltip-format": "ΎηΨ {ifname} via {gwaddri}",
        "tooltip-format-wifi": "ΎΘτ  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
        "tooltip-format-ethernet": "ΎηΨ {ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50,
        "on-click": "$HOME/.local/bin/rofi-wifi-menu.sh"
    },
    "battery": {
        "interval": 1,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "<span color=\"#9ece6a\">{icon}</span>{capacity}%",
        "format-charging": "<span color=\"#9ece6a\">ΎΩπ</span>  {capacity}%",
        "format-plugged": "ΎΘο  {capacity}%",
        "format-alt": "{icon}  {time}",
        "format-icons": [
            "≤░Β║ ",
            "≤░Β╝ ",
            "≤░Β┐ ",
            "≤░ΓΒ ",
            "≤░Β╣ "
        ]
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{volume}%  {icon}ΎΛΦ {format_source}",
        "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
        "format-muted": "Ύγσ Muted",
        "format-source": "{volume}% ΎΕ░",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "ΎΑξ ",
            "hands-free": "ΎΨΡ ",
            "headset": "ΎΨΡ ",
            "default": [
                "ΎΑο ",
                "ΎΑρ ",
                "ΎΑρ "
            ]
        },
        "on-click": "pactl set-sink-mute 0 toggle"
    },
    "bluetooth": {
        "format": "<span color=\"#7aa2f7\">ΎΛΥ</span>  On",
        "format-disabled": "<span color=\"#fff\">ΎΛΥ</span>  Off",
        "format-off": "",
        "interval": 30,
        "on-click": "blueman-manager",
        "format-no-controller": ""
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "<span color=\"#e0af68\">{icon}</span> {percent}%",
        "format-icons": [
            "≤░Δι",
            "≤░Δι"
        ]
    }
}